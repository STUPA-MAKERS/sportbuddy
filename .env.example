# PostgreSQL
POSTGRES_DB=sportpartnerboerse
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password

# Backend
PORT=3000
FRONTEND_URL=http://localhost:8094

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=changeme
SMTP_FROM=noreply@example.com
SMTP_TLS_REJECT_UNAUTHORIZED=true

# Internal API key for /email/* endpoints (X-Api-Key header)
API_SECRET=changeme_strong_secret

# Altcha (same key used by altcha-srv and backend verification)
ALTCHA_HMAC_KEY=changeme_strong_hmac_key
